# ─── LinkedIn Developer App credentials ───────────────────────────────────────
# Get these from https://www.linkedin.com/developers/apps → your app → Auth tab.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Public deployment ────────────────────────────────────────────────────────
# Public domain where this server will be reachable (no trailing slash).
# Used to build the OAuth redirect URI: ${PUBLIC_URL}/oauth/callback
# This redirect URI MUST be added in LinkedIn Developer Portal → Auth → Authorized redirect URLs.
PUBLIC_URL=https://mcp.example.com

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
DATA_DIR=./data

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Random bearer token required to access /mcp and /setup. Generate with:
#   openssl rand -hex 32
MCP_API_TOKEN=

# 32-byte hex key used to encrypt the token store at rest. Generate with:
#   openssl rand -hex 32
ENCRYPTION_KEY=
